# =============================================================================
# JID Platform — Environment Variables
# =============================================================================
# Copy to .env.local for local development. Never commit .env.local to git.
# Database & Auth: Supabase (https://supabase.com/dashboard)
# =============================================================================

# ── Supabase (required) ──────────────────────────────────────────────────────
# Cloud:
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Local (after `pnpm supabase:start` with Docker Desktop running):
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-from-supabase-start-output>
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-supabase-start-output>
# Studio: http://localhost:54323

# Server-only — never expose to the browser or NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Application URLs ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=development
