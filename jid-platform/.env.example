# =============================================================================
# JID Platform — Environment Variables
# =============================================================================
# Copy to .env.local for local development. Never commit .env.local to git.
# Database & Auth: Supabase (https://supabase.com/dashboard)
# =============================================================================

# ── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser or NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Application URLs ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=development
