# =============================================================================
# JID — NON-PRODUCTION cloud seed env (shareable friend testing)
# =============================================================================
# Copy to `.env.seed.nonprod` and fill in. Never commit `.env.seed.nonprod`.
# Never point these values at the production Supabase project or jid.sa.
# =============================================================================

# Required affirmative environment class (script refuses if unset/invalid)
SEED_ENV=nonprod

# Postgres connection string for the NON-PROD Supabase project
# Dashboard → Project Settings → Database → Connection string (URI)
# Example: postgresql://postgres.[ref]:[password]@aws-0-....pooler.supabase.com:6543/postgres
SEED_DATABASE_URL=

# Public site URL of the NON-PROD Vercel deployment friends will open
# Example: https://jid-platform-git-staging-xxxx.vercel.app
SHAREABLE_TEST_SITE_URL=

# Must match the same NON-PROD Supabase project as SEED_DATABASE_URL
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — used only for safety checks / docs printing
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_APP_ENV=staging

# Do NOT set NEXT_PUBLIC_APP_ENV=production here.
# Do NOT put SUPABASE_SERVICE_ROLE_KEY in client/Vercel public env.
# Service role is not required for this SQL seed path (uses DB URL).
